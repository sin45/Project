/* pages/Checkout/Checkout.wxss */
page {
  width: 100%;
  background-color: #e4dfdf;
  min-height: 100vh; 
  position: relative;
  padding-bottom: 100rpx;
}
.container {
  margin-top: 10rpx;
  padding: 0;  /* 移除内边距 */
  display: flex;
  align-items: flex-start;
  flex-direction: column;
}

/* 头部取餐方式与地址区域 */
.checkout-header {
  width: 100%;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

.header-tabs {
  display: flex;
}

.header-tab {
  font-size: 28rpx;
  margin-right: 40rpx;
  color: #666;
}

.header-tab.active {
  color: #006241;
  font-weight: bold;
}

.header-address {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.address-text {
  font-size: 35rpx;
  font-weight: bold;
  color: #333;
}
.store-selector {
  background-color: rgba(255, 255, 255, 0.781);
  width: 100%;
  height: 10%;
  top: 0rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

.location-input {
  display: flex;
  background-color: rgba(255, 255, 255, 0.781);
  align-items: center;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 15rpx;
}

.location-input input {
  flex: 1;
  font-size: 28rpx;
}

