<!-- pages/Checkout/Checkout.wxml -->
<view class="container">
  <!-- 头部：取餐方式 + 地址 -->
  <view class="checkout-header">
    <view class="header-tabs">
      <text class="header-tab {{orderType === 'pickup' ? 'active' : ''}}">自提</text>
      <text class="header-tab {{orderType === 'delivery' ? 'active' : ''}}">外送</text>
    </view>
    <view class="header-address">
      <text class="address-text">{{orderType === 'pickup' ? address : selectedAddress}}</text>
      <text>预计6分钟后可取餐</text>
    </view>
  </view>

  <!-- 取单时间选择 -->
