</view>

 

  <!-- 我的订单区域 -->
  <view class="order-section">
    <view class="section-header">
      <text>我的订单</text>
    </view>
  
  <!-- 修改1：动态渲染购物车商品列表 -->
  <block wx:for="{{cartItems}}" wx:key="id">
      <view class="order-item">
        <!-- 商品图片（左侧） -->
        <view class="item-image-container">
          <image class="item-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        </view>
        
        <!-- 商品信息（右侧） -->
        <view class="item-details">
          <!-- 第一行：商品名称 -->
          <view class="item-name-row">
            <text class="item-name">{{item.name}}</text>
          </view>
          
          <!-- 第二行：商品规格 -->
          <view class="item-specs">
            <!-- 修改2：显示商品定制选项 -->
            <text class="item-detail">
              {{item.selectedSize || '标准'}}/{{item.selectedTemp || '标准'}}/{{item.selectedFlavor || '标准'}}
            </text>
          </view>
          
          <!-- 第三行：价格和数量 -->
          <view class="price-quantity-row">
            <!-- 修改3：使用price字段确保价格一致 -->
            <text class="item-price">￥{{item.price}}</text>
            <view class="quantity-control">
              <view class="minus-cart-btn" bindtap="decreaseQuantity" 
                  data-id="{{item.id}}">
                <image 
                  src="/pages/images/白色减号.png" 
                  class="quantity-btn" 
                  mode="widthFix"
                />
              </view>
              <text class="quantity">{{item.quantity}}</text>
              <view class="add-cart-btn" bindtap="increaseQuantity" 
                  data-id="{{item.id}}">
                <image 
                  src="/pages/images/白色加号.png" 
                  class="quantity-btn" 
                  mode="widthFix"
                />
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
 <!-- 优惠券信息 -->
 <view class="coupon-info">
      <image class="icon" src="/pages/images/coupon1.png"></image>
      <text>星享好礼券</text>
      <text class="status1">暂无可用</text>
    
    </view>
    
    <!-- 星星信息 -->
    <view class="stars-info">
      <image class="icon" src="/pages/images/黄色星星.jpg"></image>
      <text>好礼星星</text>
      <text class="status2">暂无可用</text>
    </view>
    
    <!-- 分隔线 -->
    <view class="divider"></view>
    
    <!-- 结算信息 -->
    <view class="checkout-info">
      <view class="subtotal">
        <text>产品小计</text>
        <text>￥{{totalPrice}}</text>
      </view>
    </view>
  </view>

  <!-- 底部支付按钮 -->
  <view class="payment-bar">
    <!-- 现在没调用支付，后期改成confirmPayment -->
    <button class="pay-btn" bindtap="createOrder">支付￥{{totalPrice}}</button>
  </view>

