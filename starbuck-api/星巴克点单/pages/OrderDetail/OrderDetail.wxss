page {
  background-color: #f5f5f5; /* 设置背景颜色为浅灰色 */
}
/* 容器样式 */
.order-status-container {
  background: linear-gradient(135deg, #00704A, #006241);
  color: white;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.status-tag {
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  display: inline-block;
  margin-bottom: 16rpx;
}

.store-info {
  margin-bottom: 8rpx;
}

.store-name {
  font-size: 32rpx;
  font-weight: bold;
}

.store-address {
  font-size: 28rpx;
  opacity: 0.9;
}

.container {
  background-color: #fff;
  padding: 20rpx;
  border-radius: 10rpx;
  margin: 20rpx;
}

.qr-code-container {
  display: flex;
  justify-content: space-between;
  align-items: flex-start; /* 使子元素在交叉轴方向靠左对齐 */
  padding-bottom: 20rpx;
}

.text-container {
  display: flex;
  flex-direction: column;
  max-width: 100%; /* 设置最大宽度，避免文字过长影响二维码位置 */
}

.title {
  font-size: 32rpx;
  font-weight: normal;
  margin-bottom: 10rpx;
  margin-right: 250rpx;
  margin-top: 20rpx;
}
.description {
  font-size: 24rpx;
  color: #666;
}
.qr-code-image {
  width: 120rpx;
  height: 120rpx;
  margin-right: auto; /* 使二维码靠右对齐 */
}
.scan-button {
  background-color: #e6f7f2;
  color: #1aad19;
  border: none;
  padding: 10rpx 20rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 我的订单 */
.container-order {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}
.order-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 16rpx;
}
.order-item {
  border-bottom: 1rpx solid #f0f0f0;
  padding: 20rpx 0;
}
.order-item:last-child {
  border-bottom: none;
}
.order-item-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}
.item-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f5f5f5;
}
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}
.item-details {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.detail {
  font-size: 26rpx;
  color: #666;
  background: #f8f8f8;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-right: 8rpx;
  margin-bottom: 4rpx;
}
.item-quantity {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
  min-width: 60rpx;
  text-align: center;
}
.item-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #00704A;
  min-width: 120rpx;
  text-align: right;
}
.item-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
}
.total-label {
  font-size: 28rpx;
  color: #666;
}
.total-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #00704A;
}
.order-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-top: 2rpx solid #f0f0f0;
  margin-top: 20rpx;
}
.summary-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.summary-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #00704A;
}
.order-info {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}
.info-label {
  font-size: 28rpx;
  color: #666;
}
.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.info-value-container {
  display: flex;
  align-items: center;
}
.copy-button {
  background-color: #f5f5f5;
  border: none;
  padding: 5rpx 10rpx;
  border-radius: 5rpx;
  font-size: 24rpx;
  margin-left: 10rpx;
}
.contact-button {
  background: #00704A;
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  margin: 20rpx;
  font-size: 32rpx;
  font-weight: bold;
}
.contact-button:active {
  background: #006241;
}
.contact-text {
  color: white;
}

/* 联系客服图标 */
.fixed-circle {
  position: fixed;
  bottom: 40rpx;
  right: 40rpx;
  z-index: 1000;
}

.circle-top {
  width: 100rpx;
  height: 100rpx;
  background: #00704A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 112, 74, 0.3);
}

.icon-image {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .container-order {
    margin: 10rpx;
    padding: 16rpx;
  }
  
  .item-image {
    width: 100rpx;
    height: 100rpx;
  }
  
  .item-name {
    font-size: 28rpx;
  }
  
  .item-price {
    font-size: 28rpx;
  }
}
