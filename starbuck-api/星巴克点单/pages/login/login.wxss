.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  background: linear-gradient(135deg, #f8f8f8 0%, #408546 100%);
  padding: 40rpx;
  box-sizing: border-box;
}

.login-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
  color: #333;
}

.register-btn {
  margin-top: 20rpx;
  background: transparent;
  color: #1AAD19;
  border: 1rpx solid #1AAD19;
}

input {
  width: 100%;
  height: 90rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50rpx;
  border: none;
  font-size: 32rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

input:focus {
  box-shadow: 0 6rpx 20rpx rgba(37, 252, 84, 0.4);
  transform: translateY(-2rpx);
}

input::placeholder {
  color: #aaa;
  font-weight: 300;
}

button {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(to right, #039c31, #4be046);
  color: white;
  font-size: 36rpx;
  font-weight: 500;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 5rpx 15rpx rgba(0, 176, 155, 0.4);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

button:active {
  transform: translateY(3rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 176, 155, 0.6);
}

button::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -60%;
  width: 20rpx;
  height: 200%;
  background: rgba(255, 255, 255, 0.4);
  transform: rotate(30deg);
  transition: all 0.8s;
}

button:active::after {
  left: 120%;
}
button[loading] {
  position: relative;
  color: transparent !important;
}

button[loading]::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 40rpx;
  height: 40rpx;
  margin: -20rpx 0 0 -20rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top: 3rpx solid white;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}