<!-- 个人信息编辑页 -->
<view class="page-profile">
  <view class="form-list">
    <!-- 头像 -->
    <view class="row" bindtap="onChooseAvatar">
      <text class="label">头像</text>
      <view class="row-right">
        <image class="avatar-img" src="{{avatarUrl || '/pages/images/default-avatar.png'}}" mode="aspectFill" />
      </view>
    </view>

    <view class="divider"></view>

    <!-- 昵称 -->
    <view class="row">
      <text class="label">昵称</text>
      <input
        class="input"
        placeholder="请输入 不支持特殊字符 10个字以内"
        placeholder-class="placeholder"
        value="{{nickname}}"
        maxlength="10"
        bindinput="onNicknameInput"
      />
    </view>

    <view class="divider"></view>

    <!-- 账号（只读） -->
    <view class="row row-account">
      <text class="label">手机号</text>
      <view class="row-right col">
        <text class="account-value">{{accountMask}}</text>
        <text class="account-tip">绑定的手机号不能修改</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 性别 -->
    <view class="row" bindtap="onChooseGender">
      <text class="label">性别</text>
      <view class="row-right">
        <text class="{{genderText ? 'value' : 'placeholder'}}">{{genderText || '请选择'}}</text>
        <text class="arrow">></text>
      </view>
    </view>
  </view>

  <view class="btn-wrap">
    <button class="btn-save" bindtap="onSave">保存</button>
  </view>
</view>
