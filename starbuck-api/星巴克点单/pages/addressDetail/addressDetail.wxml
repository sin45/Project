<!-- 地址添加/编辑页 -->
<view class="page-address">
  <view class="form-list">
    <!-- 姓名 -->
    <view class="row">
      <text class="label">收件人</text>
      <view class="row-right row-input-group">
        <input
          class="input"
          placeholder="请填写姓名"
          placeholder-class="placeholder"
          value="{{receiver}}"
          bindinput="onNameInput"
        />        
      </view>
    </view>

    <view class="divider"></view>

    <!-- 手机号 -->
    <view class="row">
      <text class="label">手机号</text>
      <view class="row-right row-input-group">
        <input
          class="input"
          type="number"
          placeholder="请填写手机号"
          placeholder-class="placeholder"
          value="{{phone}}"
          maxlength="11"
          bindinput="onPhoneInput"
        />
        <text class="link-auth" bindtap="onAuthPhone">授权微信手机号</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 地区 -->
    <view class="row">
      <text class="label">地区</text>
      <view class="row-right picker-inner" bindtap="selectAddress">
        <text class="{{address1 ? 'value' : 'placeholder'}}">{{address1 || '请选择收货地址地区'}}</text>
        <text class="arrow">∨</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 详细地址 -->
    <view class="row">
      <text class="label">详细地址</text>
      <input
        class="input flex-1"
        placeholder="请选择详细地址"
        placeholder-class="placeholder"
        value="{{address2}}"
        bindinput="onDetailInput"
      />
    </view>

    <view class="divider"></view>

    <!-- 设为默认地址 -->
    <view class="row row-switch">
      <text class="label">设为默认地址</text>
      <switch checked="{{default_flag=='1'}}" color="#333" bindchange="onDefaultChange" />
    </view>
  </view>

  <view class="btn-wrap">
    <button class="btn-confirm {{if_change ? 'active' : ''}}" bindtap="onConfirm">保存</button>
  </view>
</view>
