<!-- 地址添加/编辑页 -->
<view class="page-address">
  <view class="form-list">
    <!-- 姓名 + 性别 -->
    <view class="row">
      <text class="label">姓名</text>
      <view class="row-right row-input-group">
        <input
          class="input"
          placeholder="请填写姓名"
          placeholder-class="placeholder"
          value="{{name}}"
          bindinput="onNameInput"
        />
        <view class="gender-group">
          <text class="gender-item {{gender === 1 ? 'active' : ''}}" data-value="1" bindtap="onGenderTap">先生</text>
          <text class="gender-item {{gender === 2 ? 'active' : ''}}" data-value="2" bindtap="onGenderTap">女士</text>
        </view>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 手机号 -->
    <view class="row">
      <text class="label">手机号</text>
      <view class="row-right row-input-group">
        <input
          class="input"
          type="number"
          placeholder="请填写手机号"
          placeholder-class="placeholder"
          value="{{phone}}"
          maxlength="11"
          bindinput="onPhoneInput"
        />
        <text class="link-auth" bindtap="onAuthPhone">授权微信手机号</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 地区 -->
    <view class="row">
      <text class="label">地区</text>
      <view class="row-right picker-inner" bindtap="selectAddress">
        <text class="{{regionText ? 'value' : 'placeholder'}}">{{regionText || '请选择收货地址地区'}}</text>
        <text class="arrow">∨</text>
      </view>
    </view>

    <view class="divider"></view>

    <!-- 详细地址 -->
    <view class="row">
      <text class="label">详细地址</text>
      <input
        class="input flex-1"
        placeholder="请选择详细地址"
        placeholder-class="placeholder"
        value="{{detail}}"
        bindinput="onDetailInput"
      />
    </view>

    <view class="divider"></view>

    <!-- 设为默认地址 -->
    <view class="row row-switch">
      <text class="label">设为默认地址</text>
      <switch checked="{{isDefault}}" color="#333" bindchange="onDefaultChange" />
    </view>
  </view>

  <view class="btn-wrap">
    <button class="btn-confirm" bindtap="onConfirm">确认添加</button>
  </view>
</view>
