/* index.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8f8f8;
  padding-bottom: env(safe-area-inset-bottom); /* 适配全面屏底部安全区域 */
}

/* 顶部图片样式 */
.top-image-view{
  width: 100%;
  height: 580rpx;
  display: flex;
  justify-content: center;
}

.top-image {
  width: 100%;
  height: 100%;
}

/* 内容区域样式 */
.content {
  flex: 1;
  overflow: auto;
  padding: 20rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin: 20rpx 0;
  padding-left: 10rpx;
  border-left: 6rpx solid #07c160;
}

.product-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-item {
  width: 48%;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.product-img {
  width: 100%;
  height: 280rpx;
  display: block;
}

.product-name {
  display: block;
  padding: 15rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 顶部标题栏 */
.header {
  width: 100%;
  height: 100rpx;
  background: #fff;
  color: #222;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  z-index: 10;
}

/* 广告横幅 */
.banner {
  width: 92%;
  margin: 32rpx auto 24rpx auto;
  background: linear-gradient(90deg, #036635 80%, #07c160 100%);
  border-radius: 24rpx;
  padding: 40rpx 0 32rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}
.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.banner-desc {
  font-size: 28rpx;
  margin-bottom: 24rpx;
}
.banner-btn {
  background: #fff;
  color: #036635;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 12rpx 48rpx;
  border: none;
  font-weight: bold;
}

/* 功能入口网格 */
.grid {
  width: 92%;
  margin: 0 auto 20rpx auto;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.grid-item {
  width: 22%;
  margin-bottom: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.150);
  text-align: center;
  font-size: 24rpx;
  font-weight: bold;
  color: #222;
  padding: 36rpx 0 24rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}
.grid-item image{
  width: 100rpx;
  height: 100rpx;
}

/* 让最后一行居中 */
.grid-item:nth-last-child(-n+4):nth-child(n+9) {
  margin-left: auto;
  margin-right: auto;
}

.banner-split {
  width: 92%;
  margin: 32rpx auto 60rpx auto;
  background: #f5f5f7;
  border-radius: 24rpx;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.150);  
  overflow: hidden;
}
.banner-half {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0rpx 0 24rpx 0;
  background: #FAFAFA;
  position: relative;
  z-index: 100;
}
.banner-divider {
  width: 2rpx;
  background: #e0e0e0;
  margin: 32rpx 0;
}
.banner-tag {
  background: #ff8c1a;
  color: #fff;
  font-size: 18rpx;
  border-radius: 0 0 12rpx 12rpx;
  padding: 4rpx 20rpx;
  margin-bottom: 18rpx;
}
.banner-main-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 8rpx;
}
.banner-sub-title {
  font-size: 19rpx;
  color: #888;
  margin-bottom: 18rpx;
}
.banner-img-placeholder {
  width: 200rpx;
  height: 150rpx;
  background: #FAFAFA;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.banner-img-placeholder image{
  width: 100%;
  height: 100%;
}
