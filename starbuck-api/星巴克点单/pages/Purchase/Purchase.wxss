/* pages/Purchase/Purchase.wxss */
/* 基础样式 */
page {
  width: 100%;
  background-color: #f5f5f5;
  height: 2000rpx;
  position: relative;
  padding-bottom: 100rpx;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  align-items: flex-start;
}

/* 顶部店铺信息 */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background-color: rgb(255, 255, 255);
  padding: 20rpx 30rpx 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.store-info {
  width: 100%;
  display: flex;
  justify-content: space-between;
  flex-direction: row;
  align-items: flex-start;
}

.store-chosen{
  width: 90%;
}
.store-name {
  letter-spacing: 1rpx;
  font-size: 27rpx;
  font-weight: bold;
  color: #333;
}

.store-distance {
  letter-spacing: 1rpx;
  font-size: 25rpx;
  color: rgb(0, 0, 0);
}
.immediate-text{
  letter-spacing: 1rpx;
  font-size: 20rpx;
  font-weight:340;
  color: rgb(0, 0, 0);
  margin-top: 10rpx;
  margin-bottom: 15rpx;
  display: block;
}
.action-buttons {
  width: 12%;
  position: relative;
  display: flex;
  margin-left: 20rpx;
}
.reserve-hanger {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hanger-line {
  width: 2rpx;
  height: 16rpx;
  background-color: #006241;
}

.hanger-dot {
  width: 15rpx;
  height: 15rpx;
  border-radius: 50%;
  background-color: #006241;
}
.reserve-btn {
  font-size: 23rpx;
  letter-spacing: 2rpx;
  line-height: 1; 
  padding: 10rpx 10rpx 10rpx 10rpx;/*内边距*/
  background-color: #f5f5f5;
  color: #333;
  border: 1rpx solid #8ea886;
  border-radius: 8rpx;
  margin: 0;
  line-height: 1;
  box-shadow: none;
  position: relative;
}
/* 移除按钮默认样式 */
button::after {
  border: none;
}



/* 优惠提醒 */
.promotion-bar {
    position: fixed;
    top: 120rpx; /* 根据header高度调整 */
    left: 0;
    right: 0;
    z-index: 999;
    background-color: #fff1cf;
    color: #C2A661;
    font-size: 22rpx;
    letter-spacing: 1rpx;
    padding: 20rpx 30rpx;
    border-bottom: 1rpx solid #f0f0f0;
}

/* 搜索框 */
.search-bar {
  width: 100%;
  position: fixed;
  letter-spacing: 1rpx;
  top: 192rpx; /* 根据header高度调整 */
  left: 0;
  right: 0;
  z-index: 900;
  display: flex;
  align-items: flex-start;
  padding: 30rpx 10rpx ;
  background-color: #fff;
  box-sizing: border-box; /* 确保padding不影响总宽度 */
}
.search-input-container {

  position: relative;
  width: 78%;
}

.search-input-container icon {
  position: absolute;
  left: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 1;
}
.search-input {
  width:80%;
  background-color: #f5f5f5;
  height: 60rpx; /* 增加高度使输入框更明显 */
  border-radius: 30rpx;
  margin-right: 30rpx;
  margin-bottom: 10rpx;
  padding: 0 0 0 50rpx; /* 左侧留出放大镜图标空间 */
  padding-left: 60rpx;
  font-size: 22rpx;
  flex: none;
  position: relative;
  background-size: 30rpx;
}
.PinDan-btn{
  width: 20%;
  height: 60rpx; /* 与搜索框同高 */
  background-color: #006241;
  border-radius: 30rpx;
  color: white;
  font-size: 22rpx;
  letter-spacing: 1rpx;
  display: flex; /* 添加flex布局 */
  align-items: center; /* 垂直居中 */
  justify-content: center; /* 水平居中 */
}
.help-btn{
  width: 100%; /* 占满父容器 */
  height: 100%; /* 占满父容器 */
  background-color: transparent; /* 透明背景，使用父容器颜色 */
  color: inherit; /* 继承父容器文字颜色 */
  font-size: inherit; /* 继承父容器字体大小 */
  border: none; /* 移除边框 */
  padding: 0; /* 移除内边距 */
  margin: 0; /* 移除外边距 */
  line-height: 1; /* 重置行高 */
  display: flex; /* flex布局 */
  align-items: center; /* 垂直居中 */
  justify-content: center; /* 水平居中 */
}

/* 主菜单区域 */
.menu-container {
  height: 100%;
  width: 100%;
  position:fixed;
  top:300rpx;
  bottom: 100rpx; /* 为底部结算栏留出空间 */
  display: flex;
  flex: 1;
  background-color: #fff;
  overflow: hidden;
}
.left-nav {
  width: 27%;
  background-color: #f8f8f8;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch; /* 启用iOS平滑滚动 */
}

.nav-item {
  position: relative;
  padding: 20rpx 10rpx;
  text-align: center;
  font-size: 20rpx;
  letter-spacing: 1.1px;
  line-height: 1.8;
  color: #666;
  border-left: 6rpx solid transparent;
  box-sizing: border-box;
}

.nav-item.active {
  background-color: #fff;
  color: rgb(15, 15, 15);
  font-weight: bold;
  border-left-color: #006241;
}

.badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background-color: #006241;
  color: white;
  border-radius: 50%;
  width: 30rpx;
  height: 30rpx;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}

/* 右侧内容 */
.right-content {
  width: 73%;
  max-height: calc(100vh - 300rpx - 120rpx); /* 300rpx为顶部区域，120rpx为结算栏高度 */
  overflow-y: auto;
  display: block;
  background: #fff;
}

.category-section {
  margin-bottom: 20rpx;
}

.category-title {
  padding: 10rpx 20rpx;
  width: 100%;
  font-family:h;
  font-size:22rpx;
  line-height: 2;
  letter-spacing: 1px;
  font-weight:bold;
  color: rgb(22, 21, 21);
  background-color: #f8f6f6;
}

.food-item {
  display: flex;
  padding: 20rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
}

.food-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 100rpx;
}

.food-info {
  flex: 1;
  margin-left: 20rpx;
}

.food-name {
  font-size: 28rpx;
  font-family: "Microsoft YaHei";  
  color:rgb(22, 21, 21);
  font-weight: bold;
  letter-spacing: 1px;
}

.food-desc {
  font-size: 22rpx;
  color: rgb(124, 123, 123);
  margin: 20rpx 0;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
/* 价格区域调整 */
.price-section {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.current-price {
  color: #000000;
  font-size: 28rpx;
  font-weight: bold;
  margin-top: 10px;
}

.original-price {
  color: #999;
  font-size: 24rpx;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.discount-tag {
  display: inline-block;
  margin-left: 8rpx;
  padding: 2rpx 12rpx;
  background: #ff5339;
  color: #fff;
  border-radius: 20rpx;
  font-size: 20rpx;
}

/*加入 购物车操作区域 */
.cart-action {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  margin-top: 50rpx;
}

/* 圆形加号按钮 */
.add-cart-btn {
  margin-top: 40rpx;
  margin-right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  position: absolute;
  right: 10rpx;
  background-color: #006241;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.add-cart-btn.hidden {
  display: none;
}

.add-cart-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.add-icon {
  width: 25rpx;
  height: 25rpx;
}

/* 数量控制区域 */
.quantity-control {
  display: flex;
  align-items: center;
}

.action-icon {
  width: 50rpx;
  height: 50rpx;
}

.quantity {
  margin: 0 15rpx;
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
}





/* 结算栏容器 */
.checkout-bar {
  position: fixed;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

/* 左侧信息区 */
.checkout-info {
  display: flex;
  align-items: center;
  width: 30%;
}

.coupon-info {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
  margin-left: 20rpx;
  font-size: 20rpx;
  color: #999;
}

.coupon-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 30rpx;
}

.price-info {
  display: flex;
  align-items: baseline;
}

.currency {
  font-size: 28rpx;
  margin-left: 10rpx;
  color: #000;
  font-weight: bold;
}

.total-price {
  font-size: 30rpx;
  color: #000;
  font-weight: bold;
}

/* 结算按钮 */
.checkout-btn {
  background: #cccccc;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
  padding: 20rpx 0;
  margin: 0 20rpx;
  margin-top: 10rpx;
  transition: background 0.3s;
}

.checkout-bar.active .checkout-btn {
  background: #06ad56;
  color: #fff;
}