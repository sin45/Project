/* pages/Purchase/Purchase.wxss */
/* 基础样式 */
page {
  width: 100%;
  background-color: #f5f5f5;
  min-height: 100vh;
  position: relative;
  padding-bottom: 100rpx;
}

.container {
  display: flex;
  flex-direction: column;
  height: 100%;
  align-items: flex-start;
  padding: 0 0 ;
}

/* 顶部店铺信息 */
.header {
  width: 93%;
  background-color: rgb(255, 255, 255);
  padding: 20rpx 30rpx 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.store-info {
  width: 100%;
  display: flex;
  justify-content: space-between;
  flex-direction: row;
  align-items: flex-start;
}

.store-chosen{
  width: 70%;
}
.store-name {
  letter-spacing: 1rpx;
  font-size: 27rpx;
  font-weight: bold;
  color: #333;
}


.immediate-text{
  letter-spacing: 1rpx;
  font-size: 20rpx;
  font-weight:340;
  color: rgb(0, 0, 0);
  margin-top: 10rpx;
  margin-bottom: 15rpx;
  display: block;
}

/* 自提 / 外送 切换 */
.order-type-toggle {
  display: flex;
  border-radius: 40rpx;
  overflow: hidden;
  border: 1rpx solid #e5e5e5;
  background-color: #f5f5f5;
}

.order-type-item {
  padding: 6rpx 22rpx;
  font-size: 22rpx;
  color: #666;
  background-color: transparent;
}

.order-type-item.active {
  background-color: #ffffff;
  color: #000000;
}

/* 移除按钮默认样式 */
button::after {
  border: none;
}



/* 主菜单区域 */
.menu-container {
  height: 100%;
  width: 100%;
  bottom: 100rpx; /* 为底部结算栏留出空间 */
  display: flex;
  flex: 1;
  background-color: #fff;
  overflow: hidden;
}
.left-nav {
  width: 27%;
  background-color: #f8f8f8;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch; /* 启用iOS平滑滚动 */
}

.nav-item {
  position: relative;
  padding: 20rpx 10rpx;
  text-align: center;
  font-size: 20rpx;
  letter-spacing: 1.1px;
  line-height: 1.8;
  color: #666;
  border-left: 6rpx solid transparent;
  box-sizing: border-box;
}

.nav-item.active {
  background-color: #fff;
  color: rgb(15, 15, 15);
  font-weight: bold;
  border-left-color: #006241;
}

.badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background-color: #006241;
  color: white;
  border-radius: 50%;
  width: 30rpx;
  height: 30rpx;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}

/* 右侧内容 */
.right-content {
  width: 73%;
  max-height: calc(100vh - 120rpx); /* 300rpx为顶部区域，120rpx为结算栏高度 */
  overflow-y: auto;
  display: block;
  background: #fff;
}

.category-section {
  margin-bottom: 20rpx;
}

.category-title {
  padding: 10rpx 20rpx;
  width: 100%;
  font-family:h;
  font-size:22rpx;
  line-height: 2;
  letter-spacing: 1px;
  font-weight:bold;
  color: rgb(22, 21, 21);
  background-color: #f8f6f6;
}

.food-item {
  display: flex;
  padding: 20rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
}

.food-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 100rpx;
}

.food-info {
  flex: 1;
  margin-left: 20rpx;
}

.food-name {
  font-size: 28rpx;
  font-family: "Microsoft YaHei";  
  color:rgb(22, 21, 21);
  font-weight: bold;
  letter-spacing: 1px;
}

.food-desc {
  font-size: 22rpx;
  color: rgb(124, 123, 123);
  margin: 20rpx 0;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
/* 价格区域调整 */
.price-section {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.current-price {
  color: #000000;
  font-size: 28rpx;
  font-weight: bold;
  margin-top: 10px;
}

.original-price {
  color: #999;
  font-size: 24rpx;
  text-decoration: line-through;
  margin-left: 8rpx;
}

.discount-tag {
  display: inline-block;
  margin-left: 8rpx;
  padding: 2rpx 12rpx;
  background: #ff5339;
  color: #fff;
  border-radius: 20rpx;
  font-size: 20rpx;
}

/*加入 购物车操作区域 */
.cart-action {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  margin-top: 50rpx;
}

/* 圆形加号按钮 */
.add-cart-btn {
  margin-top: 40rpx;
  margin-right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  position: absolute;
  right: 10rpx;
  background-color: #006241;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.add-cart-btn.hidden {
  display: none;
}

.add-cart-btn:active {
  transform: scale(0.9);
  opacity: 0.8;
}

.add-icon {
  width: 25rpx;
  height: 25rpx;
}

/* 数量控制区域 */
.quantity-control {
  display: flex;
  align-items: center;
}

.action-icon {
  width: 30rpx;
  height: 30rpx;
}

.quantity {
  margin: 0 15rpx;
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
}





/* 结算栏容器 */
.checkout-bar {
  position: fixed;
  bottom: 20rpx;
  left: 20rpx;
  right: 20rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

/* 左侧信息区 */
.checkout-info {
  display: flex;
  align-items: center;
  width: 30%;
}

.coupon-info {
  display: flex;
  align-items: center;
  margin-left: 20rpx;
  color: #999;
}

.coupon-icon {
  width: 70rpx;
  height: 70rpx;
  margin-right: 30rpx;
}

/* 购物车图标与数量角标 */
.cart-icon-wrapper {
  position: relative;
  display: inline-block;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: 10rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: #ff4d4f;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 6rpx rgba(0, 0, 0, 0.15);
}

.cart-badge-text {
  color: #ffffff;
  font-size: 20rpx;
}

.price-info {
  display: flex;
  align-items: baseline;
}

.currency {
  font-size: 28rpx;
  margin-left: 10rpx;
  color: #000;
  font-weight: bold;
}

.total-price {
  font-size: 30rpx;
  color: #000;
  font-weight: bold;
}

/* 结算按钮 */
.checkout-btn {
  background: #cccccc;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
  padding: 20rpx 0;
  margin: 0 20rpx;
  margin-top: 10rpx;
  transition: background 0.3s;
}

.checkout-bar.active .checkout-btn {
  background: #06ad56;
  color: #fff;
  padding-left: 25rpx;
  padding-right: 25rpx;
}

/* 购物车弹窗遮罩层 */
.cart-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 95;
}

/* 购物车弹窗主体 */
.cart-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 60vh;
  padding: 24rpx 24rpx 34rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.12);
  z-index: 96;
  padding-bottom: 110rpx;
}

.cart-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.cart-popup-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #111;
}

.cart-clear {
  font-size: 24rpx;
  color: #888;
}

.cart-popup-list {
  max-height: 50vh;
}

.cart-item {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.cart-item-image {
  width: 110rpx;
  height: 110rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.cart-item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.cart-item-title {
  font-size: 26rpx;
  color: #222;
  font-weight: 500;
}

.cart-item-sub {
  margin-top: 6rpx;
  display: flex;
  justify-content: space-between;
}

.cart-item-spec {
  font-size: 22rpx;
  color: #888;
}

.cart-item-bottom {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cart-item-price {
  font-size: 26rpx;
  color: #000;
  font-weight: bold;
}