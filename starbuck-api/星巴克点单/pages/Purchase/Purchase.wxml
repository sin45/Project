<!--pages/Purchase/Purchase.wxml-->
<view class="container">
  <!-- 顶部店铺信息 -->
  <view class="header">
    <view class="store-info">
      <view class="store-chosen">
        <text wx:if="{{orderType === 'pickup'}}" class="store-name">
          {{address}} | {{distance}}米 >
        </text>
        <text wx:if="{{orderType === 'delivery'}}" class="store-name" bindtap="changeAddress">
          {{selectedAddress ? (selectedAddress.address1 + selectedAddress.address2) : address}} >
        </text>
        <text class="immediate-text">欢迎下单</text>
      </view>
      <!-- 右上角 自提/外送 切换 -->
      <view class="order-type-toggle">
        <view 
          class="order-type-item {{orderType === 'pickup' ? 'active' : ''}}" 
          data-type="pickup" 
          bindtap="onOrderTypeChange"
        >
          自提
        </view>
        <view 
          class="order-type-item {{orderType === 'delivery' ? 'active' : ''}}" 
          data-type="delivery" 
          bindtap="onOrderTypeChange"
        >
          外送
        </view>
      </view>
    </view>
  </view>

  <!-- 主菜单区域 -->
  <view class="menu-container">
    <!-- 左侧分类 -->
    <scroll-view 
      class="left-nav" 
      scroll-y 
      scroll-with-animation 
      scroll-top="{{scrollTop}}"
      style="height: calc(100vh - 120rpx)"
>
    <block wx:for="{{categories}}" wx:key="id">
      <view class="nav-item {{currentCategory === item.id ? 'active' : ''}}" 
        bindtap="switchCategory" 
        data-id="{{item.id}}"
      >
        {{item.name}}
        <text class="badge" wx:if="{{item.count > 0}}">{{item.count}}</text>
      </view>
    </block>
  </scroll-view>
   

    <!-- 右侧商品列表 -->
  <scroll-view class="right-content" 
    scroll-y 
    scroll-with-animation 
    scroll-top="{{rightScrollTop}}"
    bindscroll="onScroll">
  <block wx:for="{{categories}}" wx:key="id">
    <view id="category-{{item.id}}" class="category-section">
      <view class="category-title">{{item.name}}</view>
      <block wx:for="{{item.foods}}" wx:key="id" >
        <view class="food-item" bindtap="goToProduct" data-id="{{item.id}}">
          <image class="food-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="food-info">
            <text class="food-name">{{item.name}}</text>
            <text class="food-desc">{{item.description}}</text>
            <view class="price-section">
              <text class="current-price">¥{{item.price}}</text>
              <text class="original-price" wx:if="{{item.originalPrice}}">¥{{item.originalPrice}}</text>
              <text class="discount-tag" wx:if="{{item.discount}}">{{item.discount}}折</text>
            </view>
          </view>
          
          <!-- 购物车操作 - 调整到与food-info同级 -->
          <view class="cart-action">
            <view 
              class="add-cart-btn {{item.quantity > 0 ? 'hidden' : ''}}" 
              data-category="{{item.categoryId}}" 
              data-id="{{item.id}}"
            >
              <image src="/pages/images/白色加号.png" class="add-icon" />
            </view>
          </view>
        </view>
      </block>
    </view>
  </block>
  </scroll-view>

  </view>

  <!-- 底部结算栏 -->
<view class="checkout-bar {{checkoutBar.active ? 'active' : ''}}">
  <view class="checkout-info">
    <view class="coupon-info">
      <view class="cart-icon-wrapper" bindtap="toggleCartPopup">
        <image class="coupon-icon" src="/pages/images/购物车.jpg"></image>
        <view class="cart-badge" wx:if="{{checkoutBar.total > 0}}">
          <text class="cart-badge-text">{{checkoutBar.total}}</text>
        </view>
      </view>
    </view>
    <view class="price-info">
      <text class="currency">¥</text>
      <text class="total-price">{{checkoutBar.price}}</text>
    </view>
  </view>
  
  <view class="checkout-btn" bindtap="checkout">
    {{checkoutBar.active ? '结算' : '未选择'}}
  </view>
</view>

<!-- 购物车弹窗 -->
  <view wx:if="{{showCart}}">
  <view class="cart-mask" bindtap="hideCartPopup"></view>
  <view class="cart-popup">
    <view class="cart-popup-header">
      <text class="cart-popup-title">已选商品</text>
      <text class="cart-clear" bindtap="clearCart">清空</text>
    </view>
    <scroll-view class="cart-popup-list" scroll-y>
      <block wx:for="{{cartItems}}" wx:key="id">
        <view class="cart-item">
          <image class="cart-item-image" src="{{item.imageUrl ? item.imageUrl : item.image}}" mode="aspectFill"></image>
          <view class="cart-item-info">
            <view class="cart-item-title">{{item.productName ? item.productName : item.name}}</view>
            <view class="cart-item-sub">
              <text class="cart-item-spec">{{item.selectedSize}} / {{item.selectedTemp}} {{item.selectedFlavor}}</text>
              <view class="quantity-control">
                <image 
                  class="action-icon" 
                  src="/pages/images/黑色减号.png" 
                  data-id="{{item.productId ? item.productId : item.id}}"
                  bindtap="decreaseCartItem"
                />
                <text class="quantity">{{item.quantity || 1}}</text>
                <image 
                  class="action-icon" 
                  src="/pages/images/黑色加号.png" 
                  data-id="{{item.productId ? item.productId : item.id}}"
                  bindtap="increaseCartItem"
                />
              </view>
            </view>
            <view class="cart-item-bottom">
              <text class="cart-item-price">¥{{(item.price || 0)}}</text>
              
            </view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>
  </view>

</view>
