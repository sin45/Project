.page-location {
  background: #ffffff;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 地图区域 */
.map-wrap {
  position: relative;
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}

.map-bg {
  width: 100%;
  height: 100%;
}

/* 中心定位点 */
.map-marker {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -100%);
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.marker-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #ffffff;
}

/* 城市 + 搜索框 */
.search-bar {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: 48rpx;
  display: flex;
  align-items: center;
}

.city {
  padding: 0 20rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  margin-right: 16rpx;
}

.city-text {
  font-size: 26rpx;
  color: #333333;
}

.city-arrow {
  font-size: 22rpx;
  color: #999999;
  margin-left: 6rpx;
}

.search-input-wrap {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
}

.placeholder {
  color: #bbbbbb;
}

/* 地址列表 */
.addr-list {
  flex: 1;
  padding: 24rpx 32rpx 32rpx;
  background: #ffffff;
}

.addr-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f2f2f2;
}

.addr-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.addr-title {
  font-size: 30rpx;
  color: #111111;
}

.addr-checked {
  font-size: 28rpx;
  color: #000000;
}

.addr-desc {
  font-size: 24rpx;
  color: #999999;
}

/* 底部确认按钮 */
.bottom-bar {
  padding: 24rpx 32rpx 40rpx;
}

.btn-confirm {
  width: 100%;
  text-align: center;
  border-radius: 44rpx;
  background: #000000;
  color: #ffffff;
  font-size: 32rpx;
  border: none;
}

.btn-confirm::after {
  border: none;
}

.btn-confirm:not(.active) {
  opacity: 0.4;
}

