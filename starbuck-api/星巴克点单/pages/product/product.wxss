/* pages/ProductDetail/ProductDetail.wxss */
.product-detail-container {
  width: 100%;
  background-color: #fff;
  padding-bottom: 160rpx;
  display: flex;
  flex-direction: column;
}

/* 商品轮播图 */
.product-gallery {
  width: 100%;
  height: 490rpx;
}
.product-gallery swiper {
  width: 100%;
  height: 100%;
}
.product-gallery image {
  width: 100%;
  height: 100%;
}

/* 商品基本信息 */
.product-base-info {
  padding: 30rpx 40rpx;
  background-color: #fff;
  border-radius: 20rpx;
  border-top: 2rpx solid #E5E5E5;
  margin-top: -35rpx;
  position: relative;
}
.product-name-row {
  margin-bottom: 16rpx; /* 增加与描述的间距 */
}
.product-name {
  font-weight: bold;
  font-size: 32rpx; /* 适当增大字号 */
  color: #333;
  line-height: 1.4; /* 优化行高 */
}
.product-description-row {
  margin-top: 16rpx; /* 与名称保持对称间距 */
}

.product-description {
  font-size: 22rpx; /* 比名称小8rpx */
  color: #333333; /* 使用深灰色增强可读性 */
  line-height: 1.6; /* 增加行距提升阅读体验 */
}

/* 定制选项区域 */
.customization-section {
  display: flex;
  padding: 50rpx;
  margin-bottom: 40rpx;
  margin-left: 20rpx;
}
.customization-row {
  margin-bottom: 40rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
}
.customization-row1{
  margin-bottom: 40rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
}
.option-title {
  font-weight: bold;
  font-size: 28rpx;
  color: rgb(36, 36, 36);
  margin-left: 20rpx;
}

/* 数量控制 */
.quantity-control {
  display: flex;
  flex-direction: row;
  justify-content: flex-end; /* 内容靠右 */
  margin-right: 20rpx;
}
.quantity-btn {
  width: 35rpx;
  height: 35rpx;
  border-radius: 50%;
  background-color: #006241;
  display: flex;
  justify-content: center;
  align-items: center;
}
.decrease-btn {
  background-color: #d1d1d1;
}
.btn-icon {
  width: 28rpx;
  height: 28rpx;
}
.quantity {
  margin: 0 32rpx;
  font-size: 28rpx;
  color: #333;
  min-width: 40rpx;
  text-align: center;
}

/* 杯型选择 */
.size-options {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  margin-left: 15rpx;
  margin-right: 15rpx;
}
.size-option {
  width: 155rpx;
  height: 90rpx;
  border: 1rpx solid #E5E5E5;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}
.size-option.selected {
  border-color: #1A714B;
  font-weight: bold;
  color: #08744A;
}
.size-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 30rpx;
}
.size-icon image {
  width: 100%;
  height: 100%;
}
.size-info {
  text-align: center;
}
.size-name {
  font-size: 22rpx;
  color: #000;
}
.size-volume {
  font-size: 20rpx;
  color: #999;
}
.selected-text {
  font-weight: bold;
  color: #1A714B;
}

/* 温度选择 */
.temperature-options {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  margin-left: 20rpx;
  margin-right: 20rpx;
}
.temperature-option {
  width: 210rpx;
  height: 50rpx;
  border-radius: 16rpx;
  border: 1rpx solid #E5E5E5;
  font-size: 24rpx;
  color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.temperature-option.selected {
  border-color: #1A714B;
  font-weight: bold;
  color: #08744A;
}

/* 浓缩咖啡选择 */
.espresso-options {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  margin-right: 15rpx;
  margin-left: 15rpx;
}
.espresso-option {
  width: 190rpx;
  height: 80rpx;
  border-radius: 16rpx;
  border: 1rpx solid #E5E5E5;
  font-size: 22rpx;
  color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 0 10rpx;
}
.espresso-option.selected {
  border-color: #1A714B;
  font-weight: bold;
  color: #08744A;
}

/* 浓缩类型详情 */
.espresso-detail-section {
  border-radius: 16rpx;
  margin-top: 20rpx;
  padding: 20rpx;
  border: 1rpx solid #E5E5E5;
  margin-right: 30rpx;
  margin-left: 30rpx;
}
.espresso-types {
  display: flex;
  justify-content: space-between;

}
.espresso-type {
  width: 210rpx;
  height: 230rpx;
  border-radius: 20rpx;
  border: 1rpx solid #8e998d;
  text-align: center;
  padding-top: 30rpx;
  margin-left: 15rpx;
  margin-right: 15rpx;
}
.espresso-type image {
  width:40rpx;
  height: 60rpx;
}
.type-name {
  font-size: 22rpx;
  font-weight: bold;
  color: #000;
}
.type-description {
  font-size: 20rpx;
  color: #999;
  padding: 0 20rpx;
  display: block;
  margin-top: 10rpx;
}
.espresso-quantity {
  height: 35rpx;
  margin-top: 40rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  background-color: #D8F2E6;
  color: #1A714B;
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

/* 固定底部操作栏 */
.fixed-bottom-bar {
  width: 100%;
  border-top: 1rpx solid #E5E5E5;
  position: fixed;
  left: 0;
  bottom: 0;
  padding: 35rpx;
  background-color: white;
  display: flex;
  justify-content: space-around;
  align-items: center;
  z-index: 100;
}
.reset-btn {
  min-width: 250rpx;
  height: 80rpx;
  color: #1A714B;
  background-color: white;
  border: 3rpx solid #1A714B;
  border-radius: 50rpx;
  text-align: center;
  font-weight: bolder;
  line-height: 80rpx;
}
.add-to-cart-btn {
  width: 500rpx;
  height: 80rpx;
  background-color: #006241;
  color: #fff;
  border: 2rpx solid #006241;
  border-radius: 50rpx;
  font-size: 26rpx;
  line-height: 40rpx;
  text-align: center;
  font-weight: bolder;
}

/* 滚动时显示的固定标题 */
.sticky-product-header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 200rpx;
  background: #fff;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  padding: 50rpx 30rpx ;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}
.sticky-product-header image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 70rpx;
}
.header-info {
  width: 360rpx;
  height: 70rpx;
  margin-left: 20rpx;
  margin-bottom: 40rpx;
}
.header-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
  display: block;
}
.header-desc {
  font-size: 20rpx;
  color: #999;
}
.divider {
  height: 80rpx;
  width: 1rpx;
  background: #cacaca;
  margin: 0 20rpx 0 20rpx;
}
.save-customization {
  width: 150rpx;
  height: 50rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: row;
  justify-content: center;
  text-align: center;
}
.save-customization image {
  width: 70rpx;
  height: 40rpx;
  margin: 10rpx;
}
.save-customization text {
  font-size: 22rpx;
  color: rgb(71, 71, 71);
}